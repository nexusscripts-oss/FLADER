-- Fling target, then steal from spawnpoint, return to plot center
local function runAdvancedPacedHarvestSequence(targetPlot)
    if not isNightOrMoonActive() then
        print("[System Info] Activation Denied: Daytime active.")
        return
    end

    if not targetPlot or targetPlot.Parent == nil then return end
    
    local myPlot = getMyPlot()
    local plantsFolder = targetPlot:FindFirstChild("Plants")
    local targetSpawnPoint = targetPlot:FindFirstChild("SpawnPoint")
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    
    if not myPlot or not plantsFolder or not rootPart or not targetSpawnPoint then return end
    
    fruitsHarvestedThisRun = 0

    -- Step 1: Evaluate target actions
    local targetOwnerName = targetPlot:GetAttribute("Owner")
    if targetOwnerName then
        local targetPlayer = Players:FindFirstChild(targetOwnerName)
        if targetPlayer and targetPlayer.Character then
            local tChar = targetPlayer.Character
            local tHum = tChar:FindFirstChildOfClass("Humanoid")
            local tRoot = tChar:FindFirstChild("HumanoidRootPart")
            
            if tHum and tRoot then
                local isMoving = tHum.MoveDirection.Magnitude > 0.1
                local isAtSpawn = (tRoot.Position - targetSpawnPoint.Position).Magnitude < 12
                
                if isMoving then
                    StatusLabel.Text = "Status: Flinging Active Target..."
                    pcall(function() executeTargetDisplacementSequence(targetPlayer, targetSpawnPoint) end)
                    task.wait(0.2)
                elseif isAtSpawn then
                    StatusLabel.Text = "Status: Target parked at Spawn. Poking..."
                    pcall(function() executeTargetDisplacementSequence(targetPlayer, targetSpawnPoint) end)
                    task.wait(0.2)
                end
            end
        end
    end
    
    if not isNightOrMoonActive() then 
        print("[System Info] Execution Aborted: Night/Moon phase finished before warp step.")
        showTopWarningNotification() 
        return 
    end

    -- Step 2: Teleport to their spawnpoint and steal
    rootPart.Anchored = false
    teleportToLocation(targetSpawnPoint.CFrame + Vector3.new(0, 3, 0))
    task.wait(0.1)
    
    local keepTeleporting = true
    task.spawn(function()
        while keepTeleporting do
            task.wait(2)
            if keepTeleporting and cycleStealAllEnabled and targetSpawnPoint then
                teleportToLocation(targetSpawnPoint.CFrame + Vector3.new(0, 3, 0))
            end
        end
    end)
    
    for _, plantModel in pairs(plantsFolder:GetChildren()) do
        local fruitsFolder = plantModel:FindFirstChild("Fruits")
        if fruitsFolder then
            for _, fruitModel in pairs(fruitsFolder:GetChildren()) do
                if not cycleStealAllEnabled then 
                    keepTeleporting = false
                    return 
                end
                if fruitsHarvestedThisRun >= 50 then break end
                
                local harvestPart = fruitModel:FindFirstChild("HarvestPart")
                local prompt = harvestPart and (harvestPart:FindFirstChild("StealPrompt") or harvestPart:FindFirstChild("HarvestPrompt"))
                
                if prompt and prompt:IsA("ProximityPrompt") then
                    prompt.MaxActivationDistance = 100
                    if typeof(fireproximityprompt) == "function" then fireproximityprompt(prompt) end
                    fruitsHarvestedThisRun = fruitsHarvestedThisRun + 1
                    StatusLabel.Text = "Status: Stealing (" .. fruitsHarvestedThisRun .. "/50)"
                    task.wait(0.05)
                end
            end
        end
    end
    
    keepTeleporting = false 
    
    -- Step 3: Run return escape routing directly to PlotSizeReference part
    executeEscapeToSizeReference()
    
    task.wait(0.2)
    fruitsHarvestedThisRun = 0
end

