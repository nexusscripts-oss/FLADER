-- Re-architected movement system block using clean while verification gates
local function executeTargetDisplacementSequence(TargetPlayer, targetSpawnPoint)
    local Character = player.Character
    local Humanoid = Character and Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Humanoid and Humanoid.RootPart
    local TCharacter = TargetPlayer.Character
    if not TCharacter then return end
    
    local THumanoid = TCharacter:FindFirstChildOfClass("Humanoid")
    local TRootPart = THumanoid and THumanoid.RootPart
    local THead = TCharacter:FindFirstChild("Head")
    local Accessory = TCharacter:FindFirstChildOfClass("Accessory")
    local Handle = Accessory and Accessory:FindFirstChild("Handle")
    
    if Character and Humanoid and RootPart then
        if RootPart.Velocity.Magnitude < 50 then
            getgenv().OldPos = RootPart.CFrame
        end
        
        if THumanoid and THumanoid.Sit then
            return
        end
        
        if THead then
            workspace.CurrentCamera.CameraSubject = THead
        elseif Handle then
            workspace.CurrentCamera.CameraSubject = Handle
        elseif THumanoid and TRootPart then
            workspace.CurrentCamera.CameraSubject = THumanoid
        end
        
        if not TCharacter:FindFirstChildWhichIsA("BasePart") then
            return
        end
        
        local FPos = function(BasePart, Pos, Ang)
            if RootPart and RootPart.Parent and BasePart and BasePart.Parent then
                RootPart.CFrame = CFrame.new(BasePart.Position) * Pos * Ang
                Character:SetPrimaryPartCFrame(CFrame.new(BasePart.Position) * Pos * Ang)
                RootPart.Velocity = Vector3.new(9e7, 9e7 * 10, 9e7)
                RootPart.RotVelocity = Vector3.new(9e8, 9e8, 9e8)
            end
        end
        
        local SFBasePart = function(BasePart)
            local TimeToWait = 10 
            local Time = tick()
            local Angle = 0
            
            while tick() < Time + TimeToWait do
                local CurrentCharacter = player.Character
                local CurrentRootPart = CurrentCharacter and CurrentCharacter:FindFirstChild("HumanoidRootPart")
                
                if not CurrentRootPart or not TargetPlayer.Character then 
                    break 
                end
                
                local CurrentTCharacter = TargetPlayer.Character
                local CurrentTHumanoid = CurrentTCharacter:FindFirstChildOfClass("Humanoid")
                local CurrentTRoot = CurrentTCharacter:FindFirstChild("HumanoidRootPart")
                
                if CurrentTHumanoid and CurrentTHumanoid.Sit then
                    break
                end
                
                -- [[ INTELLIGENT GATE REWRITE ]] 
                if CurrentTHumanoid and CurrentTHumanoid.MoveDirection.Magnitude < 0.1 and targetSpawnPoint and CurrentTRoot then
                    local distanceFromSpawn = (CurrentTRoot.Position - targetSpawnPoint.Position).Magnitude
                    if distanceFromSpawn < 12 then
                        break
                    end
                end
                
                if BasePart and BasePart.Parent then
                    if BasePart.Velocity.Magnitude < 50 then
                        Angle = Angle + 100
                        FPos(BasePart, CFrame.new(0, 1.5, 0) + CurrentTHumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                        task.wait()
                        FPos(BasePart, CFrame.new(0, -1.5, 0) + CurrentTHumanoid.MoveDirection * BasePart.Velocity.Magnitude / 1.25, CFrame.Angles(math.rad(Angle), 0, 0))
                        task.wait()
                    end
                else
                    break
                end
            end
        end
        
        workspace.FallenPartsDestroyHeight = 0/0
        
        local BV = Instance.new("BodyVelocity")
        BV.Parent = RootPart
        BV.Velocity = Vector3.new(0, 0, 0)
        BV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
        
        if TRootPart then
            SFBasePart(TRootPart)
        elseif THead then
            SFBasePart(THead)
        elseif Handle then
            SFBasePart(Handle)
        else
            BV:Destroy()
            return
        end
        
        BV:Destroy()
        Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
        workspace.CurrentCamera.CameraSubject = Humanoid
        
        if getgenv().OldPos then
            -- [[ FIXED EXCLUSIVELY TO PLOT SIZEREFERENCE ]]
            local myPlot = getMyPlot()
            local targetReturnCFrame = getgenv().OldPos
            
            if myPlot then
                local sizeRef = myPlot:FindFirstChild("PlotSizeReference")
                if sizeRef and sizeRef:IsA("BasePart") then
                    targetReturnCFrame = sizeRef.CFrame + Vector3.new(0, 5, 0)
                end
            end

            repeat
                if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then break end
                local CurrentRoot = player.Character.HumanoidRootPart
                local CurrentHum = player.Character:FindFirstChildOfClass("Humanoid")
                
                CurrentRoot.CFrame = targetReturnCFrame
                player.Character:SetPrimaryPartCFrame(targetReturnCFrame)
                if CurrentHum then CurrentHum:ChangeState("GettingUp") end
                
                for _, part in pairs(player.Character:GetChildren()) do
                    if part:IsA("BasePart") then
                        part.Velocity, part.RotVelocity = Vector3.new(), Vector3.new()
                    end
                end
                task.wait()
            until not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") or (player.Character.HumanoidRootPart.Position - targetReturnCFrame.p).Magnitude < 25
            workspace.FallenPartsDestroyHeight = getgenv().FPDH
        end
    end
end

