-- Helper function to detect any special moon or night state
local function isNightOrMoonActive()
    return Workspace:FindFirstChild("ActiveNight") 
        or Workspace:FindFirstChild("RainbowMoon") 
        or Workspace:FindFirstChild("Bloodmoon") 
        or Workspace:FindFirstChild("ChainedMoon") 
        or Workspace:FindFirstChild("Goldmoon")
end

-- Helper: Safe Path Finder
local function byPassWaitForChild(parent, path, timeout)
    local current = parent
    for segment in string.gmatch(path, "[^%.]+") do
        current = current:WaitForChild(segment, timeout)
        if not current then return nil end
    end
    return current
end

-- Helper: Locate personal plot
local function getMyPlot()
    for _, plot in pairs(GARDENS_FOLDER:GetChildren()) do
        if plot:GetAttribute("Owner") == playerName then
            return plot
        end
    end
    return nil
end

-- Teleport Logic Execution
local function teleportToLocation(cframe)
    local character = player.Character
    if character then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            character:PivotTo(cframe)
            return true
        end
    end
    return false
end

-- Core Escape Protocol: Direct routing to PlotSizeReference
local function executeEscapeToSizeReference()
    local myPlot = getMyPlot()
    if myPlot then
        local sizeRef = myPlot:FindFirstChild("PlotSizeReference")
        if sizeRef and sizeRef:IsA("BasePart") then
            teleportToLocation(sizeRef.CFrame + Vector3.new(0, 5, 0))
            return true
        end
    end
    return false
end

