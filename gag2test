                    local targetFound = false
                    for _, plot in pairs(GARDENS_FOLDER:GetChildren()) do
                        if not cycleStealAllEnabled or stealTargetOnlyEnabled then break end
                        local ownerName = plot:GetAttribute("Owner")
                        if ownerName and ownerName ~= playerName then
                            targetFound = true
                            StatusLabel.Text = "Status: Full Plot Complete -> " .. ownerName
                            pcall(function() runAdvancedPacedHarvestSequence(plot) end)
                            task.wait(0.5)
                        end
                    end
                    if not targetFound then
                        StatusLabel.Text = "Status: No valid targets on map."
                        task.wait(1)
                    end
                end
            else
                task.wait(0.1)
            end
        end
    end
end)
