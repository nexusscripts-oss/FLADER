-- Helper: Locate personal plot
local function getMyPlot()
    for _, plot in pairs(GARDENS_FOLDER:GetChildren()) do
        if plot:GetAttribute("Owner") == playerName then
            return plot
        end
    end
    return nil
end

-- Helper: Dynamic Nearest Plot Checker
local function getNearestPlot()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end

    local closestPlot = nil
    local shortestDistance = math.huge

    for _, plot in pairs(GARDENS_FOLDER:GetChildren()) do
        local spawnPoint = plot:FindFirstChild("SpawnPoint")
        if spawnPoint and spawnPoint:IsA("BasePart") then
            local distance = (rootPart.Position - spawnPoint.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestPlot = plot
            end
        end
    end
    return closestPlot
end

-- Teleport Logic Execution
local function teleportToLocation(cframe)
    local character = player.Character
    if character then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            character:PivotTo(cframe)
            return true
        end
    end
    return false
end

-- Direct Aggressive Button Clicker
local function clickImageButton(button)
    if getconnections then
        local events = {"MouseButton1Click", "Activated", "MouseButton1Down", "MouseButton1Up"}
        for _, eventName in pairs(events) do
            local conns = getconnections(button[eventName])
            for _, conn in pairs(conns) do 
                conn:Fire() 
            end
        end
    end
    
    pcall(function()
        local absPos = button.AbsolutePosition
        local absSize = button.AbsoluteSize
        local centerCheckX = absPos.X + (absSize.X / 2)
        local centerCheckY = absPos.Y + (absSize.Y / 2) + 58 
        
        VirtualInputManager:SendMouseButtonEvent(centerCheckX, centerCheckY, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(centerCheckX, centerCheckY, 0, false, game, 1)
    end)
end

-- Dynamically Refresh and Populate Teleport Dropdown
local function refreshTeleportMenu()
    for _, child in pairs(TeleportMenu:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    local plots = GARDENS_FOLDER:GetChildren()
    table.sort(plots, function(a, b) return a.Name < b.Name end)
    local nearestPlot = getNearestPlot()

    for _, plot in pairs(plots) do
        local ownerName = plot:GetAttribute("Owner")
        local displayName = ownerName and (ownerName .. "'s Garden") or (plot.Name .. " (Unowned)")
        
        local OptionBtn = Instance.new("TextButton")
        OptionBtn.Size = UDim2.new(1, -4, 0, 28)
        OptionBtn.BackgroundColor3 = Color3.fromRGB(32, 32, 44)
        OptionBtn.BorderSizePixel = 0
        OptionBtn.Text = "     " .. displayName
        OptionBtn.TextColor3 = ownerName == playerName and Color3.fromRGB(0, 230, 130) or Color3.fromRGB(220, 220, 220)
        OptionBtn.TextSize = 11
        OptionBtn.Font = Enum.Font.GothamMedium
        OptionBtn.TextXAlignment = Enum.TextXAlignment.Left
        OptionBtn.ZIndex = 6
        OptionBtn.Parent = TeleportMenu

        local OptionCorner = Instance.new("UICorner")
        OptionCorner.CornerRadius = UDim.new(0, 4)
        OptionCorner.Parent = OptionBtn

        if nearestPlot and plot == nearestPlot then
            local Dot = Instance.new("Frame")
            Dot.Size = UDim2.new(0, 6, 0, 6)
            Dot.Position = UDim2.new(0, 8, 0.5, -3)
            Dot.BackgroundColor3 = Color3.fromRGB(0, 230, 130)
            Dot.BorderSizePixel = 0
            Dot.ZIndex = 7
            Dot.Parent = OptionBtn
            local Dc = Instance.new("UICorner") Dc.CornerRadius = UDim.new(1,0) Dc.Parent = Dot
        end

        OptionBtn.MouseButton1Click:Connect(function()
            local spawnPoint = plot:FindFirstChild("SpawnPoint")
            if spawnPoint then
                teleportToLocation(spawnPoint.CFrame + Vector3.new(0, 3, 0))
                StatusLabel.Text = "Status: Warped to " .. plot.Name
            end
            tpDropdownOpen = false
            TeleportMenu.Visible = false
            TeleportMenu.Size = UDim2.new(1, -24, 0, 0)
            TeleportToggleBtn.Text = "Teleport To... v"
        end)
    end
    TeleportMenu.CanvasSize = UDim2.new(0, 0, 0, TeleportLayout.AbsoluteContentSize.Y)
end

