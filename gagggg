    local function getNearestPlot()
        local character = player.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        if not rootPart then return nil end
        local closestPlot, shortestDistance = nil, math.huge
        for _, plot in pairs(GARDENS_FOLDER:GetChildren()) do
            local spawnPoint = plot:FindFirstChild("SpawnPoint")
            if spawnPoint and spawnPoint:IsA("BasePart") then
                local dist = (rootPart.Position - spawnPoint.Position).Magnitude
                if dist < shortestDistance then shortestDistance = dist closestPlot = plot end
            end
        end
        return closestPlot
    end

