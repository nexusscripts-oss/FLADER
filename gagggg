    -- HARVEST / STEAL LOGIC
    local function runAdvancedPacedHarvestSequence(targetPlot)
        if not isNightOrMoonActive() then return end
        if not targetPlot or targetPlot.Parent == nil then return end
        local myPlot = getMyPlot()
        local plantsFolder = targetPlot:FindFirstChild("Plants")
        local targetSpawnPoint = targetPlot:FindFirstChild("SpawnPoint")
        local character = player.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        if not myPlot or not plantsFolder or not rootPart or not targetSpawnPoint then return end
        fruitsHarvestedThisRun = 0
        rootPart.Anchored = false
        teleportToLocation(targetSpawnPoint.CFrame + Vector3.new(0, 3, 0))
        task.wait(0.1)

        local keepTeleporting = true
        task.spawn(function()
            while keepTeleporting do
                task.wait(2)
                if keepTeleporting and cycleStealAllEnabled and targetSpawnPoint then
                    teleportToLocation(targetSpawnPoint.CFrame + Vector3.new(0, 3, 0))
                end
            end
        end)

        for _, plantModel in pairs(plantsFolder:GetChildren()) do
            local seedName = plantModel:GetAttribute("SeedName")
            local allowed = (plantFilterModes[seedName] == "Whitelist" and selectedPlantsFilter[seedName])
                         or (plantFilterModes[seedName] == "Blacklist" and not selectedPlantsFilter[seedName])
            if allowed then
                local fruitsFolder = plantModel:FindFirstChild("Fruits")
                if fruitsFolder then
                    local fruits = fruitsFolder:GetChildren()

                    if selectedStealMode == "Steal Best Fruits" then
                        table.sort(fruits, function(a, b)
                            return calculateFruitPrices(seedName, a) > calculateFruitPrices(seedName, b)
                        end)
                    elseif selectedStealMode == "Steal Only Mutated" then
                        local filtered = {}
                        for _, fr in ipairs(fruits) do
                            if fr:GetAttribute("Mutation") then table.insert(filtered, fr) end
                        end
                        fruits = filtered
                    elseif selectedStealMode == "Steal Heaviest" then
                        table.sort(fruits, function(a, b)
                            local wA = (PLANT_BASE_WEIGHTS[seedName] or 1) * (a:GetAttribute("SizeMulti") or 1)
                            local wB = (PLANT_BASE_WEIGHTS[seedName] or 1) * (b:GetAttribute("SizeMulti") or 1)
                            return wA > wB
                        end)
                    elseif selectedStealMode == "Random Steal" then
                        for i = #fruits, 2, -1 do
                            local j = math.random(i)
                            fruits[i], fruits[j] = fruits[j], fruits[i]
                        end
                    end
                    -- "Steal Normal Fruits" = no sort, as-is

                    for _, fruit in pairs(fruits) do
                        if not cycleStealAllEnabled then keepTeleporting = false return end
                        if fruitsHarvestedThisRun >= 50 then break end
                        local hp = fruit:FindFirstChild("HarvestPart")
                        local prompt = hp and (hp:FindFirstChild("StealPrompt") or hp:FindFirstChild("HarvestPrompt"))
                        if prompt and prompt:IsA("ProximityPrompt") then
                            prompt.MaxActivationDistance = 100
                            if typeof(fireproximityprompt) == "function" then fireproximityprompt(prompt) end
                            fruitsHarvestedThisRun = fruitsHarvestedThisRun + 1
                            StatusLabel.Text = "SYSTEM ENVIRONMENT: RAIDING (" .. fruitsHarvestedThisRun .. "/50)"
                            task.wait(0.05)
                        end
                    end
                end
            end
        end

        keepTeleporting = false
        executeEscapeToSizeReference()
        task.wait(0.2)
        fruitsHarvestedThisRun = 0
    end

