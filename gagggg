-- CALCULATION ENGINE
local function calculateFruitPrices(seedName, fruitModel)
    local sizeMulti = fruitModel:GetAttribute("SizeMulti") or 1
    local baseValue = PLANT_BASE_VALUES[seedName] or 5
    local exponent = PLANT_EXPONENTS[seedName] or 2.65
    local priceWithoutMutation = math.floor(baseValue * math.pow(sizeMulti, exponent))
    local mutationType = fruitModel:GetAttribute("Mutation")
    local multiplier = 1
    local hasMutation = false
    if mutationType and MUTATION_MULTIPLIERS[mutationType] then
        multiplier = MUTATION_MULTIPLIERS[mutationType]
        hasMutation = true
    end
    return priceWithoutMutation * multiplier, priceWithoutMutation, hasMutation
end

-- BILLBOARD LABEL SYSTEM
local function cloneAndFormatPrompt(originalPromptLabel, finalPrice, basePrice, hasMutation)
    local clonedGui = originalPromptLabel:Clone()
    clonedGui.Name = "CalculatedPriceRadarTag"
    clonedGui.ExtentsOffset = originalPromptLabel.ExtentsOffset - Vector3.new(0, 1.2, 0)
    local frame = clonedGui:FindFirstChild("Frame")
    if frame then
        local targetMutations = frame:FindFirstChild("Mutations")
        if targetMutations then targetMutations:Destroy() end
        local nameLabel = frame:FindFirstChild("Name")
        if nameLabel and nameLabel:IsA("TextLabel") then
            nameLabel.RichText = true
            if PREDICTION_ACTIVE then
                if hasMutation then
                    nameLabel.Text = string.format('Around: <font color="#00BF00">%d Sheckles</font> <font color="#FFFFFF">%d Without Mutations</font>', finalPrice, basePrice)
                else
                    nameLabel.Text = string.format('Around: <font color="#00BF00">%d Sheckles</font>', finalPrice)
                end
            else
                nameLabel.Text = "Price Prediction: OFF"
            end
        end
    end
    clonedGui.Parent = originalPromptLabel.Parent
    return clonedGui
end

