            local plantsFolder = plot:FindFirstChild("Plants")
            if plantsFolder then
                for _, plantModel in ipairs(plantsFolder:GetChildren()) do
                    if plantModel:IsA("Model") then
                        local seedName = plantModel:GetAttribute("SeedName")
                        local fruitsFolder = plantModel:FindFirstChild("Fruits")
                        if seedName and fruitsFolder then
                            for _, fruitModel in ipairs(fruitsFolder:GetChildren()) do
                                if fruitModel:IsA("Model") then
                                    local harvestPart = fruitModel:FindFirstChild("HarvestPart")
                                    local originalPrompt = harvestPart and harvestPart:FindFirstChild("HarvestPromptLabel")
                                    if originalPrompt and originalPrompt:IsA("BillboardGui") then
                                        validFruits[fruitModel] = true
                                        local label = activeLabels[fruitModel]
                                        if not label or label.Parent == nil then
                                            local finalPrice, basePrice, hasMutation = calculateFruitPrices(seedName, fruitModel)
                                            label = cloneAndFormatPrompt(originalPrompt, finalPrice, basePrice, hasMutation)
                                            activeLabels[fruitModel] = label
                                        else
                                            -- Update label if SizeMulti changed
                                            local frame = label:FindFirstChild("Frame")
                                            if frame and PREDICTION_ACTIVE then
                                                local nameLabel = frame:FindFirstChild("Name")
                                                if nameLabel and nameLabel:IsA("TextLabel") then
                                                    local finalPrice2, basePrice2, hasMutation2 = calculateFruitPrices(seedName, fruitModel)
                                                    nameLabel.RichText = true
                                                    if hasMutation2 then
                                                        nameLabel.Text = string.format('Around: <font color="#00BF00">%d Sheckles</font> <font color="#FFFFFF">%d Without Mutations</font>', finalPrice2, basePrice2)
                                                    else
                                                        nameLabel.Text = string.format('Around: <font color="#00BF00">%d Sheckles</font>', finalPrice2)
                                                    end
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end

        for fruitModel, label in pairs(activeLabels) do
            if not validFruits[fruitModel] or not fruitModel.Parent then
                if label and label.Parent then label:Destroy() end
                activeLabels[fruitModel] = nil
            end
        end
    end)

