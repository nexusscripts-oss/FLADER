    -- GLOBAL CLICK SELECT RAYCAST (from ClickSelectBtn in header)
    UserInputService.InputBegan:Connect(function(input, processed)
        if clickSelectActive and not processed then
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                local camera = workspace.CurrentCamera
                if not camera then clickSelectActive = false return end
                local ray = camera:ScreenPointToRay(input.Position.X, input.Position.Y)
                local raycastParams = RaycastParams.new()
                raycastParams.FilterType = Enum.RaycastFilterType.Exclude
                raycastParams.FilterDescendantsInstances = {player.Character or workspace}
                local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, raycastParams)
                local resolvedSeedName = nil
                if result and result.Instance then
                    local hitInstance = result.Instance
                    if hitInstance:GetAttribute("Height") ~= nil then
                        local model = hitInstance:FindFirstAncestorOfClass("Model")
                        if model then resolvedSeedName = model:GetAttribute("SeedName") end
                    else
                        local p1 = hitInstance.Parent
                        local p2 = p1 and p1.Parent
                        if p2 and p2:GetAttribute("SeedName") ~= nil then
                            resolvedSeedName = p2:GetAttribute("SeedName")
                        elseif p1 and p1:GetAttribute("SeedName") ~= nil then
                            resolvedSeedName = p1:GetAttribute("SeedName")
                        else
                            local current = hitInstance
                            for i = 1, 4 do
                                if not current or current == workspace then break end
                                if current:GetAttribute("SeedName") ~= nil then
                                    resolvedSeedName = current:GetAttribute("SeedName") break
                                end
                                current = current.Parent
                            end
                        end
                    end
                end
                if resolvedSeedName and PLANT_BASE_WEIGHTS[resolvedSeedName] ~= nil then
                    selectedPlantsFilter[resolvedSeedName] = true
                    createTopRightNotify("SCANNER CAPTURED", "Auto-engaged plant toggle: " .. resolvedSeedName, THEME_ACCENT)
                    if plantDropdownOpen then refreshPlantMenu() end
                else
                    createTopRightNotify("SCANNER ERROR", "Object outside structural asset bounds.", Color3.fromRGB(230, 80, 80))
                end
                clickSelectActive = false
                ClickSelectBtn.Text = "Click Select Tool: INACTIVE"
                ClickSelectBtn.BackgroundColor3 = Color3.fromRGB(28, 28, 36)
                css.Color = Color3.fromRGB(45, 45, 55)
            end
        end
    end)

